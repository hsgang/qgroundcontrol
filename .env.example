# Build-time credentials baked into the binary at CMake configure time.
#
# Usage (local):
#   1. cp .env.example .env      (or .env.local — .env.local wins over .env)
#   2. fill in the values below
#   3. just configure && just build   (re-run configure whenever values change)
#
# Precedence: real environment variable > .env.local > .env > built-in default.
# Both .env and .env.local are git-ignored. NEVER commit real secrets.
#
# Only non-empty values override the shipped defaults; leave a line blank/removed
# to keep the default (STUN, auth client id, and the Supabase keys already have
# working defaults, so you normally only need the two WebRTC lines below).

# --- WebRTC (typical local/deploy setup: just these two) ---
QGC_WEBRTC_SIGNALING_SERVER=
QGC_WEBRTC_AUTH_CLIENT_SECRET=

# --- WebRTC (optional; usually left blank — TURN is server-issued, STUN/id have defaults) ---
QGC_WEBRTC_STUN_SERVER=
QGC_WEBRTC_TURN_SERVER=
QGC_WEBRTC_TURN_USERNAME=
QGC_WEBRTC_TURN_PASSWORD=
QGC_WEBRTC_AUTH_CLIENT_ID=

# --- Supabase ---
# Neither value is hardcoded anymore — set BOTH to use Supabase features
# (sign-in, uploads). Leaving them blank leaves Supabase inert.
QGC_SUPABASE_HOST=
QGC_SUPABASE_ANON_KEY=

# NOTE: ICE bind address is intentionally NOT here — it is a per-machine local IP
# and must be entered in the app settings on each PC, not baked into the build.