{
    "version": 1,
    "fileType": "SettingsUI",
    "groups": [
        {
            "heading": "SIYI Device",
            "keywords": ["siyi", "model", "device", "mk15", "mk32", "unirc", "preset"],
            "controls": [
                {
                    "setting": "siyiSettings.siyiDeviceModel"
                }
            ]
        },
        {
            "heading": "UniRC 7 (UDP)",
            "keywords": ["siyi", "unirc", "udp", "datalink", "19856", "192.168.144.20", "relay", "mavlink", "14550"],
            "controls": [
                {
                    "setting": "siyiSettings.siyiUniRCEnabled"
                },
                {
                    "setting": "siyiSettings.siyiUniRCIp",
                    "control": "textfield",
                    "showWhen": "QGroundControl.settingsManager.siyiSettings.siyiUniRCEnabled.value"
                },
                {
                    "setting": "siyiSettings.siyiUniRCRelayPort",
                    "control": "textfield",
                    "showWhen": "QGroundControl.settingsManager.siyiSettings.siyiUniRCEnabled.value"
                }
            ]
        },
        {
            "component": "SiyiUniRCTransportSection",
            "sectionName": "UniRC 7 Transport",
            "showWhen": "QGroundControl.settingsManager.siyiSettings.siyiUniRCEnabled.value",
            "keywords": ["siyi", "unirc", "serial", "uart", "transport", "udp", "port", "baud"]
        },
        {
            "component": "SiyiUniRCStatusSection",
            "sectionName": "UniRC 7 Status",
            "showWhen": "QGroundControl.settingsManager.siyiSettings.siyiUniRCEnabled.value",
            "keywords": ["siyi", "unirc", "hardware id", "battery", "pairing", "joystick", "firmware", "rssi", "signal"]
        },
        {
            "component": "SiyiUniRCChannelSection",
            "sectionName": "UniRC 7 Channel Mapping / Reverse",
            "showWhen": "QGroundControl.settingsManager.siyiSettings.siyiUniRCEnabled.value",
            "keywords": ["siyi", "unirc", "channel", "mapping", "reverse", "joystick", "switch"]
        },
        {
            "component": "SiyiUniRCRcChannelsSection",
            "sectionName": "UniRC 7 RC Channels",
            "showWhen": "QGroundControl.settingsManager.siyiSettings.siyiUniRCEnabled.value",
            "keywords": ["siyi", "unirc", "rc", "channels", "live", "stick", "frequency", "output"]
        },
        {
            "heading": "Transmitter (TCP)",
            "keywords": ["siyi", "transmitter", "tcp", "5864", "192.168.144.12", "image link"],
            "controls": [
                {
                    "setting": "siyiSettings.siyiTransmitterEnabled"
                },
                {
                    "setting": "siyiSettings.siyiTransmitterIp",
                    "control": "textfield",
                    "showWhen": "QGroundControl.settingsManager.siyiSettings.siyiTransmitterEnabled.value"
                }
            ]
        },
        {
            "heading": "Camera / Gimbal (TCP)",
            "keywords": ["siyi", "camera", "gimbal", "tcp", "37256", "192.168.144.25"],
            "controls": [
                {
                    "setting": "siyiSettings.siyiCameraEnabled"
                },
                {
                    "setting": "siyiSettings.siyiCameraIp",
                    "control": "textfield",
                    "showWhen": "QGroundControl.settingsManager.siyiSettings.siyiCameraEnabled.value"
                }
            ]
        }
    ]
}
